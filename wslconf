#!/bin/bash
# Usage: sudo wslconf on|off|status|reset

WSL_CONF="/etc/wsl.conf"

conf_status() {
    if grep -q "^systemd=true" "$WSL_CONF" 2>/dev/null; then
        echo "systemd: ON"
    elif grep -q "^systemd=false" "$WSL_CONF" 2>/dev/null; then
        echo "systemd: OFF"
    else
        echo "systemd: <not configured> (default: OFF)"
    fi
}

conf_set_systemd() {
    local val="$1"
    local label="$2"

    if grep -q "^systemd=" "$WSL_CONF" 2>/dev/null; then
        sudo sed -i "s/^systemd=.*/systemd=${val}/" "$WSL_CONF"
    elif grep -q "^\[boot\]" "$WSL_CONF" 2>/dev/null; then
        sudo sed -i "/^\[boot\]/a systemd=${val}" "$WSL_CONF"
    else
        printf "\n[boot]\nsystemd=%s\n" "$val" | sudo tee -a "$WSL_CONF" > /dev/null
    fi
    echo "systemd set to ${label}"
    echo "⚠  Reboot WSL to take effect: wsl.exe --shutdown"
}

conf_reset() {
    sudo tee "$WSL_CONF" > /dev/null <<'EOF'
[boot]
systemd=false

[user]
default=will

[automount]
enabled=false
mountFsTab=true
options=metadata,umask=22,fmask=11

[interop]
appendWindowsPath=false
enabled=true
EOF
    echo "wsl.conf reset to defaults"
    echo "⚠  Reboot WSL to take effect: wsl.exe --shutdown"
}

case "${1:-status}" in
    on|enable|1|true)
        conf_set_systemd "true" "ON"
        ;;
    off|disable|0|false)
        conf_set_systemd "false" "OFF"
        ;;
    reset)
        conf_reset
        ;;
    status|-s)
        conf_status
        ;;
    *)
        echo "Usage: sudo $0 on|off|status|reset"
        exit 1
        ;;
esac